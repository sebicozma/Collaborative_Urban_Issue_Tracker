# Copy this file to .env and edit as needed.

# Mock mode serves canned data from src/api/mock/ — handy for UI work without
# the backend. Set to "true" to enable it; anything else hits the real gateway.
EXPO_PUBLIC_USE_MOCK=false

# API gateway base URL. On a physical device, replace localhost with the dev
# machine's LAN IP (the phone can't reach the computer's localhost).
EXPO_PUBLIC_API_URL=http://localhost:3000
