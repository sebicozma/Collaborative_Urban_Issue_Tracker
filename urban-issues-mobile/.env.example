# Copy to .env and set to your dev machine's LAN IP (not localhost) so a physical
# device running Expo Go can reach the Identity server over Wi-Fi.
EXPO_PUBLIC_OIDC_ISSUER=http://<your-lan-ip>:5222
EXPO_PUBLIC_OIDC_CLIENT_ID=urban-issues-mobile

# Reports API base URL. Use the gateway (port 3000) which proxies /reports to the
# reports-service. On Android, tunnel it: `adb reverse tcp:3000 tcp:3000`.
# Pointing straight at the reports-service (http://<your-lan-ip>:8081) also works.
EXPO_PUBLIC_API_BASE_URL=http://<your-lan-ip>:3000
