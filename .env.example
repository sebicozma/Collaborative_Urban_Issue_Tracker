# Copy to .env and fill in. The .env file is gitignored — never commit real values.
GMAIL_APP_PASSWORD=

# OpenAI key for the AI classification service. Without it every report.created
# event dead-letters and reports stay SUBMITTED forever.
OPENAI_API_KEY=

# Recipient for report status-change notification emails. Leave empty to skip them.
ADMIN_NOTIFICATION_EMAIL=

# Optional: override the OpenAI model used for classification.
# MODEL_VERSION=gpt-4o-mini-2024-07-18
