@page
@model UrbanIssuesIdentity.Pages.Account.LogoutModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign out — Urban Issues Identity</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 420px; margin: 4rem auto; padding: 0 1rem; }
        h1 { font-size: 1.4rem; margin-bottom: 1rem; }
        button { padding: 0.6rem 1.2rem; font-size: 1rem; }
    </style>
</head>
<body>
    <h1>Sign out</h1>

    @if (!string.IsNullOrEmpty(Model.ClientName))
    {
        <p>You are signing out from <strong>@Model.ClientName</strong>.</p>
    }

    <p>Are you sure you want to sign out?</p>

    <form method="post">
        <input type="hidden" name="LogoutId" value="@Model.LogoutId" />
        <button type="submit">Yes, sign me out</button>
    </form>
</body>
</html>
