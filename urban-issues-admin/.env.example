# Copy to .env.local and fill in real values (.env.local is gitignored).

# IdentityServer (Duende) issuer — must exactly match the discovery doc `issuer`.
# The dockerized identity service listens on http://localhost:5222.
OIDC_ISSUER=http://localhost:5222

# Confidential client registered in UrbanIssuesIdentity/Config.cs.
OIDC_CLIENT_ID=urban-issues-admin
OIDC_CLIENT_SECRET=dev-admin-secret

# Must match the client's RedirectUris / PostLogoutRedirectUris byte-for-byte.
# The admin app runs on port 3001 (port 3000 belongs to the API gateway).
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3001/

# Reports service base URL, used server-side to load map markers.
REPORTS_API_URL=http://localhost:8081

# Encrypts/signs the iron-session cookie. Use >= 32 random chars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
IRON_SESSION_PASSWORD=replace-with-32+-random-characters
